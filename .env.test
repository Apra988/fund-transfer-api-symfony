APP_ENV=test
APP_SECRET=test_secret_change_in_ci
# Base name `app`; test env applies `dbname_suffix: _test` (see config/packages/doctrine.yaml) → database `app_test`.
DATABASE_URL="mysql://app:app@127.0.0.1:3306/app?serverVersion=8.4.0&charset=utf8mb4"
REDIS_URL=redis://127.0.0.1:6379
LOCK_DSN=flock
API_KEY=

# PHPUnit often overrides via phpunit.xml.dist (lower burst for deterministic 429 tests).
TRANSFER_WRITE_RATE_LIMIT=200
